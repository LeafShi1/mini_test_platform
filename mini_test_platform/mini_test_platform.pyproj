<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>89fb64be-ee71-48a1-8306-8b4d5cae728f</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>main.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>mini_test_platform</Name>
    <RootNamespace>mini_test_platform</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="config\config_loader.py" />
    <Compile Include="loader\test_loader.py" />
    <Compile Include="logger\logger_manager.py" />
    <Compile Include="main.py" />
    <Compile Include="reporter\html_reporter.py" />
    <Compile Include="runner\test_runner.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="loader\" />
    <Folder Include="logs\" />
    <Folder Include="config\" />
    <Folder Include="logger\" />
    <Folder Include="reports\" />
    <Folder Include="tests\" />
    <Folder Include="reporter\" />
    <Folder Include="runner\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="config.yaml" />
    <Content Include="tests\test_cases.json" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
